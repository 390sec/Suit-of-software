# Improved Python Automation Code

This version:

✔ searches
✔ visits multiple pages
✔ follows related links
✔ collects large text datasets

```python
import time
import requests
from bs4 import BeautifulSoup
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.chrome.options import Options


QUERY = "engineering internships contract work knowledge systems"
MAX_SEARCH_RESULTS = 20
MAX_PAGES_TO_VISIT = 50
OUTPUT_FILE = "elite_collection.txt"


visited_urls = set()
collected_text = ""


def start_browser():

    options = Options()
    options.add_argument("--headless")
    options.add_argument("--disable-gpu")

    service = Service("/usr/bin/chromedriver")

    driver = webdriver.Chrome(service=service, options=options)

    return driver


def search_query(driver, query):

    driver.get("https://duckduckgo.com")

    search_box = driver.find_element(By.NAME, "q")

    search_box.send_keys(query)
    search_box.submit()

    time.sleep(3)

    links = driver.find_elements(By.CSS_SELECTOR, "a.result__a")

    urls = []

    for link in links[:MAX_SEARCH_RESULTS]:
        urls.append(link.get_attribute("href"))

    return urls


def extract_page_text(url):

    try:
        response = requests.get(url, timeout=10)

        soup = BeautifulSoup(response.text, "html.parser")

        paragraphs = soup.find_all("p")

        text = ""

        for p in paragraphs:
            text += p.get_text() + "\n"

        return text, soup

    except:
        return "", None


def extract_related_links(soup):

    links = []

    for tag in soup.find_all("a", href=True):

        url = tag["href"]

        if url.startswith("http"):
            links.append(url)

    return links


def crawl_information(driver):

    global collected_text

    queue = search_query(driver, QUERY)

    while queue and len(visited_urls) < MAX_PAGES_TO_VISIT:

        url = queue.pop(0)

        if url in visited_urls:
            continue

        print("Collecting:", url)

        visited_urls.add(url)

        text, soup = extract_page_text(url)

        collected_text += text

        if soup:

            new_links = extract_related_links(soup)

            for link in new_links:
                if link not in visited_urls:
                    queue.append(link)

        time.sleep(2)

    with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
        f.write(collected_text)


def main():

    driver = start_browser()

    crawl_information(driver)

    driver.quit()

    print("Knowledge collection completed.")


if __name__ == "__main__":
    main()
```

